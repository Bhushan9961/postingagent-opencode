# =============================================================================
# AI Marketing OS — Environment Variables
# =============================================================================

# --- NVIDIA NIM API (LLM, Image, Voice, Embedding) ---
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ai_marketing_os

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT / Authentication ---
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- SocialClaw (Publisher) ---
SC_API_KEY=sc_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Cloudflare R2 (Storage) ---
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=ai-marketing-assets
R2_PUBLIC_URL=https://your-bucket.r2.cloudflarestorage.com

# --- ComfyUI (Video Generation) ---
COMFYUI_URL=http://localhost:8188
COMFYUI_TIMEOUT=600

# --- Firecrawl / Crawl4AI (Web Scraping) ---
# FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Frontend ---
NUXT_PUBLIC_API_URL=http://localhost:8000

# --- App ---
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO