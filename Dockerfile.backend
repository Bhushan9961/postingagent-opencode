FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev && \
    rm -rf /var/lib/apt/lists/*

COPY packages/shared-types/ ./packages/shared-types/
COPY packages/agent-core/ ./packages/agent-core/
COPY packages/llm-client/ ./packages/llm-client/
COPY apps/backend/pyproject.toml ./apps/backend/
COPY apps/backend/app/ ./apps/backend/app/

RUN pip install --no-cache-dir -e packages/shared-types \
    && pip install --no-cache-dir -e packages/agent-core \
    && pip install --no-cache-dir -e packages/llm-client \
    && pip install --no-cache-dir -e "apps/backend[dev]"

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
